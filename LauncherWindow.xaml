<Window x:Class="MartianGamesAlerts.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Martian Games Launcher"
        Height="520" Width="780"
        MinHeight="400" MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <!-- ================ Games column ================ -->
        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Games" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <ItemsControl x:Name="GamesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="210" Height="180" Margin="0,0,10,10"
                                    Background="#F7F7F8"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid Margin="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding DisplayName}"
                                               FontSize="15" FontWeight="SemiBold"/>

                                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding SizeText}"    Foreground="#666" FontSize="11"/>
                                        <TextBlock Text="{Binding UpdatedText}" Foreground="#666" FontSize="11"/>
                                        <TextBox   Text="{Binding StatusText, Mode=OneWay}"
                                                   IsReadOnly="True"
                                                   BorderThickness="0"
                                                   Background="Transparent"
                                                   Padding="0"
                                                   Foreground="#333"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"
                                                   IsTabStop="False"
                                                   Cursor="Arrow"/>
                                        <ProgressBar Value="{Binding ProgressValue}"
                                                     Visibility="{Binding ProgressVisibility}"
                                                     Height="4" Margin="0,6,0,0"
                                                     Minimum="0" Maximum="100"/>
                                    </StackPanel>

                                    <Button Grid.Row="2"
                                            Content="{Binding ActionText}"
                                            IsEnabled="{Binding ActionEnabled}"
                                            Click="OnTileAction"
                                            Padding="0,6"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="GamesEmpty"
                           Text="No games available. (Check that ManifestId is set in your settings.)"
                           Foreground="#888" FontStyle="Italic"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ================ News column ================ -->
        <Border Grid.Row="0" Grid.Column="1"
                BorderBrush="#EEE" BorderThickness="1,0,0,0"
                Padding="14,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Upcoming events"
                           FontSize="14" FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl x:Name="NewsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding When}"
                                                   Foreground="#888" FontSize="10"
                                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding GameName}"
                                                   Foreground="#888" FontSize="10" FontStyle="Italic"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Body}"
                                                   TextWrapping="Wrap" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NewsEmpty"
                                   Text="No upcoming events."
                                   Foreground="#888" FontStyle="Italic"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ================ Bottom bar ================ -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText" Foreground="#666" VerticalAlignment="Center"/>
            <Button   Grid.Column="1" Content="Refresh" Click="OnRefresh" Padding="16,6"/>
        </Grid>
    </Grid>
</Window>
